{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "snowid-server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/snowid-server",
      // 命令行 flag 一个一个写成数组元素。--worker-id 是必填的。
      "args": [
        "--addr", ":50052",
        "--worker-id", "1",
        "--node-bits", "7",
        "--step-bits", "12"
        "--datacenter-bits", "4"
        "--datacenter-id", "1"
      ],
      // 也可以改用环境变量传 worker-id（模拟 K8s 的 downward API）。
      // args 里已给了 --worker-id 时 flag 优先，这里可留空。
      "env": {
        // "SNOWID_WORKER_ID": "0"
      }
    }
  ]
}
